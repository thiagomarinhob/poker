# PostgreSQL
POSTGRES_DB=poker
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend (poker-backend/.env)
PORT=8080
ENV=development
DATABASE_URL=postgres://poker:poker@localhost:5432/poker_db?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-32-plus-chars
